{
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "family": "learnapp-TaskDefinition-prod",
    "containerDefinitions": [
        {
            "name": "learnJenikinsApp",
            "image": "nginx:1.26-alpine",
            "portMappings": [{
                "name": "nginx-80",
                "containerPort": 80,
                "hostPort": 80,
                "protocol": "tcp",
                "appProtocol": "http"
            }],
            "essential": true
        }
    ],
    "volumes": [],
    "networkMode": "awsvpc",
    "memory": "3 GB",
    "cpu": "1 vCPU",
    "executionRoleArn": ""
}